{% load i18n %}
<aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">
  <!-- ! Hide app brand if navbar-full -->
  {% if not navbar_full %}
  <div class="app-brand demo">
    <a href="{% url 'index' %}" class="app-brand-link">
      <span class="app-brand-logo demo">
        {% include 'partials/logo.html' %}
      </span>
      <span class="app-brand-text demo menu-text fw-bold ms-2">{% get_theme_variables 'template_name' %}</span>
    </a>

    <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large ms-auto d-block d-xl-none">
      <i class="icon-base bx bx-chevron-left icon-sm d-flex align-items-center justify-content-center"></i>
    </a>
  </div>
  {% endif %}

  <div class="menu-inner-shadow"></div>

  <ul class="menu-inner py-1">
    <!-- Dashboard -->
    <li class="menu-item {% if request.resolver_match.url_name == 'index' or request.resolver_match.url_name == 'dashboard' %}active{% endif %}">
      <a href="{% url 'index' %}" class="menu-link">
        <i class="menu-icon icon-base bx bx-home-smile"></i>
        <div class="text-truncate">{% trans "Dashboard" %}</div>
      </a>
    </li>

    <li class="menu-header small text-uppercase">
      <span class="menu-header-text">{% trans "Tracking Management" %}</span>
    </li>

    <!-- Issues -->
    <li class="menu-item {% if 'issue' in request.resolver_match.url_name %}active open{% endif %}">
      <a href="javascript:void(0);" class="menu-link menu-toggle">
        <i class="menu-icon icon-base bx bx-bug"></i>
        <div class="text-truncate">{% trans "Fault Registry" %}</div>
      </a>
      <ul class="menu-sub">
        <li class="menu-item {% if request.resolver_match.url_name == 'issue-list' %}active{% endif %}">
          <a href="{% url 'issue-list' %}" class="menu-link">
            <div class="text-truncate">{% trans "List All" %}</div>
          </a>
        </li>
        <li class="menu-item {% if request.resolver_match.url_name == 'issue-create' %}active{% endif %}">
          <a href="{% url 'issue-create' %}" class="menu-link">
            <div class="text-truncate">{% trans "New Report" %}</div>
          </a>
        </li>
      </ul>
    </li>

    {% if request.user.is_admin %}
    <li class="menu-header small text-uppercase">
        <span class="menu-header-text">{% trans "System Administration" %}</span>
      </li>

    <!-- Systems -->
    <li class="menu-item {% if 'system' in request.resolver_match.url_name %}active open{% endif %}">
      <a href="javascript:void(0);" class="menu-link menu-toggle">
        <i class="menu-icon icon-base bx bx-collection"></i>
        <div class="text-truncate">{% trans "Systems" %}</div>
      </a>
      <ul class="menu-sub">
        <li class="menu-item {% if request.resolver_match.url_name == 'system-list' %}active{% endif %}">
          <a href="{% url 'system-list' %}" class="menu-link">
            <div class="text-truncate">{% trans "Configure" %}</div>
          </a>
        </li>
        <li class="menu-item {% if request.resolver_match.url_name == 'system-create' %}active{% endif %}">
          <a href="{% url 'system-create' %}" class="menu-link">
            <div class="text-truncate">{% trans "Add New" %}</div>
          </a>
        </li>
      </ul>
    </li>

    <!-- Screens -->
    <li class="menu-item {% if 'screen' in request.resolver_match.url_name %}active open{% endif %}">
      <a href="javascript:void(0);" class="menu-link menu-toggle">
        <i class="menu-icon icon-base bx bx-slideshow"></i>
        <div class="text-truncate">{% trans "App Screens" %}</div>
      </a>
      <ul class="menu-sub">
        <li class="menu-item {% if request.resolver_match.url_name == 'screen-list' %}active{% endif %}">
          <a href="{% url 'screen-list' %}" class="menu-link">
            <div class="text-truncate">{% trans "Manage" %}</div>
          </a>
        </li>
        <li class="menu-item {% if request.resolver_match.url_name == 'screen-create' %}active{% endif %}">
          <a href="{% url 'screen-create' %}" class="menu-link">
            <div class="text-truncate">{% trans "Assign Screen" %}</div>
          </a>
        </li>
      </ul>
    </li>

    <!-- Groups -->
    <li class="menu-item {% if 'group' in request.resolver_match.url_name %}active open{% endif %}">
      <a href="javascript:void(0);" class="menu-link menu-toggle">
        <i class="menu-icon icon-base bx bx-lock-open-alt"></i>
        <div class="text-truncate">{% trans "Access Groups" %}</div>
      </a>
      <ul class="menu-sub">
        <li class="menu-item {% if request.resolver_match.url_name == 'group-list' %}active{% endif %}">
          <a href="{% url 'group-list' %}" class="menu-link">
            <div class="text-truncate">{% trans "All Permissions" %}</div>
          </a>
        </li>
        <li class="menu-item {% if request.resolver_match.url_name == 'group-create' %}active{% endif %}">
          <a href="{% url 'group-create' %}" class="menu-link">
            <div class="text-truncate">{% trans "Create Group" %}</div>
          </a>
        </li>
      </ul>
    </li>

    <!-- Users -->
    <li class="menu-item {% if 'user' in request.resolver_match.url_name %}active open{% endif %}">
      <a href="javascript:void(0);" class="menu-link menu-toggle">
        <i class="menu-icon icon-base bx bx-user-circle"></i>
        <div class="text-truncate">{% trans "Membership" %}</div>
      </a>
      <ul class="menu-sub">
        <li class="menu-item {% if request.resolver_match.url_name == 'user-list' %}active{% endif %}">
          <a href="{% url 'user-list' %}" class="menu-link">
            <div class="text-truncate">{% trans "User Directory" %}</div>
          </a>
        </li>
        <li class="menu-item {% if request.resolver_match.url_name == 'user-create' %}active{% endif %}">
          <a href="{% url 'user-create' %}" class="menu-link">
            <div class="text-truncate">{% trans "Register User" %}</div>
          </a>
        </li>
      </ul>
    </li>
    {% endif %}

  </ul>
</aside>

